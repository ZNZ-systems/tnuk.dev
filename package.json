{
  "name": "tnuk.dev",
  "version": "0.1.0",
  "description": "Thermo-nuclear team code review — pre-push quality gate powered by the bundled Cursor SDK",
  "type": "module",
  "license": "MIT",
  "author": "Panos Zepos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZNZ-systems/tnuk.dev.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/ZNZ-systems/tnuk.dev/issues"
  },
  "homepage": "https://tnuk.dev",
  "keywords": [
    "cursor",
    "cursor-sdk",
    "git-hooks",
    "pre-push",
    "code-review",
    "cli"
  ],
  "bin": {
    "tnuk": "dist/cli.js",
    "thermo-review": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "skill",
    "LICENSE",
    "README.md"
  ],
  "workspaces": [
    "dashboard",
    "worker"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "build:dashboard": "npm run build -w tnuk-dashboard",
    "build:worker": "npm run typecheck -w tnuk-worker",
    "setup:worker": "node scripts/setup-worker.mjs",
    "setup:clerk-webhook": "node scripts/setup-clerk-webhook.mjs",
    "dev": "tsc --watch",
    "dev:dashboard": "npm run dev -w tnuk-dashboard",
    "typecheck": "npm run build:worker && npm run build:dashboard",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.13",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
